@model MeuErp.Models.LoginViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - MeuErp</title>
    <link rel="stylesheet" href="~/css/login.css" asp-append-version="true" />
</head>
<body class="login-body">
    <!-- Background Animated Blobs -->
    <div class="bg-blob bg-blob-1"></div>
    <div class="bg-blob bg-blob-2"></div>

    <div class="login-container">
        <div class="login-card">
            <div class="brand-logo">
                <h1>MeuErp</h1>
                <p>Gestão Inteligente de Estoque</p>
            </div>

            <form asp-controller="Account" asp-action="Login" asp-route-returnUrl="@ViewBag.ReturnUrl" method="post">
                @Html.AntiForgeryToken()

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="validation-summary-errors-custom">
                        <div asp-validation-summary="ModelOnly"></div>
                        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <div>@error.ErrorMessage</div>
                        }
                    </div>
                }

                <div class="form-group-custom">
                    <label asp-for="Username"></label>
                    <div class="input-icon-wrapper">
                        <input asp-for="Username" class="form-input-custom" placeholder="Digite seu usuário" autofocus autocomplete="username" />
                    </div>
                    <span asp-validation-for="Username" class="field-validation-error-custom"></span>
                </div>

                <div class="form-group-custom">
                    <label asp-for="Password"></label>
                    <div class="input-icon-wrapper">
                        <input asp-for="Password" class="form-input-custom" placeholder="Digite sua senha" autocomplete="current-password" />
                    </div>
                    <span asp-validation-for="Password" class="field-validation-error-custom"></span>
                </div>

                <div class="form-options">
                    <label class="remember-me-label">
                        <input asp-for="RememberMe" class="remember-me-checkbox" />
                        @Html.DisplayNameFor(m => m.RememberMe)
                    </label>
                </div>

                <button type="submit" class="btn-login">Acessar Sistema</button>
            </form>
        </div>
    </div>

    @await Html.PartialAsync("_ValidationScriptsPartial")
</body>
</html>
