@model IEnumerable<MeuErp.Models.StockMovement>
@{
    ViewData["Title"] = "Movimentações de Estoque";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="page-title mb-0">Histórico de Movimentações</h1>
    <a asp-action="Create" class="btn btn-primary shadow-sm">Nova Movimentação</a>
</div>

<div class="card p-4">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>Data e Hora</th>
                    <th>Produto</th>
                    <th class="text-center">Tipo</th>
                    <th class="text-center">Quantidade</th>
                    <th>Observações</th>
                    <th class="text-center" style="width: 180px;">Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model) {
                    <tr>
                        <td class="text-white">@item.MovementDate.ToString("dd/MM/yyyy HH:mm")</td>
                        <td class="fw-medium text-white">@Html.DisplayFor(modelItem => item.Product!.Name)</td>
                        <td class="text-center">
                            @if (item.Type == MeuErp.Models.MovementType.Entry) {
                                <span class="badge bg-success">Entrada</span>
                            } else {
                                <span class="badge bg-danger">Saída</span>
                            }
                        </td>
                        <td class="text-center fw-bold text-white">@Html.DisplayFor(modelItem => item.Quantity)</td>
                        <td class="text-muted">@Html.DisplayFor(modelItem => item.Description)</td>
                        <td class="text-center">
                            <div class="d-flex gap-2 justify-content-center">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary py-1 px-3">Editar</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger py-1 px-3">Excluir</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
