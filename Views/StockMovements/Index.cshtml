@model IEnumerable<MeuErp.Models.StockMovement>

@{
    ViewData["Title"] = "Movimentações de Estoque";
}

<h1>Histórico de Movimentações</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Nova Movimentação</a>
</p>
<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>Data e Hora</th>
            <th>Produto</th>
            <th>Tipo</th>
            <th>Quantidade</th>
            <th>Observações</th>
            <th>Ações</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model) {
            <tr>
                <td>@item.MovementDate.ToString("dd/MM/yyyy HH:mm")</td>
                <td>@Html.DisplayFor(modelItem => item.Product!.Name)</td>
                <td>
                    @if (item.Type == MeuErp.Models.MovementType.Entry) {
                        <span class="badge bg-success">Entrada</span>
                    } else {
                        <span class="badge bg-danger">Saída</span>
                    }
                </td>
                <td>@Html.DisplayFor(modelItem => item.Quantity)</td>
                <td>@Html.DisplayFor(modelItem => item.Description)</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Editar</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Excluir</a>
                </td>
            </tr>
        }
    </tbody>
</table>
