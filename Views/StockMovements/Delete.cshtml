@model MeuErp.Models.StockMovement

@{
    ViewData["Title"] = "Excluir Movimentação";
}

<h1>Excluir Movimentação</h1>
<h3>Tem certeza de que deseja excluir esta movimentação? Isso reverterá a quantidade no estoque do produto!</h3>
<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Produto</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Product!.Name)</dd>

        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Type)</dt>
        <dd class="col-sm-10">
            @if (Model.Type == MeuErp.Models.MovementType.Entry) {
                <span class="badge bg-success">Entrada</span>
            } else {
                <span class="badge bg-danger">Saída</span>
            }
        </dd>

        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Quantity)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Quantity)</dd>
        
        <dt class="col-sm-2">Data</dt>
        <dd class="col-sm-10">@Model.MovementDate.ToString("dd/MM/yyyy HH:mm")</dd>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Excluir" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
    </form>
</div>
