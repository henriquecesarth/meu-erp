@model MeuErp.Models.StockMovement
@{
    ViewData["Title"] = "Excluir Movimentação";
}

<div class="mb-4">
    <h1 class="page-title text-center">Excluir Movimentação</h1>
</div>

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card p-4" style="border-color: rgba(239, 68, 68, 0.4) !important;">
            <h2 class="fs-4 text-danger mb-3 fw-bold text-center">Atenção!</h2>
            <p class="text-secondary text-center mb-4">Tem certeza de que deseja excluir esta movimentação? <strong>Isso reverterá a quantidade no estoque do produto!</strong></p>
            
            <div class="p-3 rounded mb-4" style="background: rgba(255, 255, 255, 0.02); border: 1px solid rgba(255, 255, 255, 0.04);">
                <dl class="row mb-0" style="row-gap: 10px;">
                    <dt class="col-sm-4 text-muted mb-0">Produto:</dt>
                    <dd class="col-sm-8 text-white fw-bold mb-0">@Html.DisplayFor(model => model.Product!.Name)</dd>

                    <dt class="col-sm-4 text-muted mb-0">Tipo:</dt>
                    <dd class="col-sm-8 text-white mb-0">
                        @if (Model.Type == MeuErp.Models.MovementType.Entry) {
                            <span class="badge bg-success">Entrada</span>
                        } else {
                            <span class="badge bg-danger">Saída</span>
                        }
                    </dd>

                    <dt class="col-sm-4 text-muted mb-0">Quantidade:</dt>
                    <dd class="col-sm-8 text-white mb-0">@Html.DisplayFor(model => model.Quantity)</dd>

                    <dt class="col-sm-4 text-muted mb-0">Data:</dt>
                    <dd class="col-sm-8 text-white mb-0">@Model.MovementDate.ToString("dd/MM/yyyy HH:mm")</dd>
                </dl>
            </div>
            
            <form asp-action="Delete" class="d-flex gap-3 justify-content-end">
                <input type="hidden" asp-for="Id" />
                <a asp-action="Index" class="btn btn-outline-secondary px-4">Cancelar</a>
                <button type="submit" class="btn btn-outline-danger px-4">Excluir Registro</button>
            </form>
        </div>
    </div>
</div>
