@model IEnumerable<MeuErp.Models.Product>

@{
    ViewData["Title"] = "Dashboard";
}

<div class="mb-5 mt-4">
    <h1 class="page-title text-center">Visão Geral do Estoque</h1>
</div>

<div class="row mb-5">
    <div class="col-md-4">
        <div class="card card-metric-purple mb-4">
            <div class="card-body">
                <h5 class="card-title text-uppercase text-muted fw-bold" style="font-size: 0.85rem; letter-spacing: 0.5px;">Total de Produtos</h5>
                <p class="card-text display-4 fw-bold mb-0 text-white">@ViewBag.TotalProducts</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card card-metric-red mb-4">
            <div class="card-body">
                <h5 class="card-title text-uppercase text-muted fw-bold" style="font-size: 0.85rem; letter-spacing: 0.5px;">Estoque Baixo</h5>
                <p class="card-text display-4 fw-bold mb-0 text-danger" style="text-shadow: 0 0 10px rgba(239, 68, 68, 0.25);">@ViewBag.LowStock</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card card-metric-orange mb-4">
            <div class="card-body">
                <h5 class="card-title text-uppercase text-muted fw-bold" style="font-size: 0.85rem; letter-spacing: 0.5px;">Estoque Alto</h5>
                <p class="card-text display-4 fw-bold mb-0 text-warning" style="text-shadow: 0 0 10px rgba(245, 158, 11, 0.25);">@ViewBag.HighStock</p>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-6 mb-4">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-transparent border-0 pt-4 pb-0">
                <h3 class="card-title text-white fs-4 fw-bold">Produtos Críticos</h3>
            </div>
            <div class="card-body">
                <ul class="list-group list-group-flush bg-transparent">
                    @foreach(var item in Model.Where(p => p.Quantity < p.MinQuantity || p.Quantity > p.MaxQuantity).Take(5))
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center px-0 bg-transparent">
                            <span class="fw-medium text-white">@item.Name</span>
                            <span>
                                @if(item.Quantity < item.MinQuantity) { 
                                    <span class="badge bg-danger">Abaixo do mín (@item.Quantity/@item.MinQuantity)</span> 
                                }
                                @if(item.Quantity > item.MaxQuantity) { 
                                    <span class="badge bg-warning text-dark">Acima do máx (@item.Quantity/@item.MaxQuantity)</span> 
                                }
                            </span>
                        </li>
                    }
                    @if(!Model.Any(p => p.Quantity < p.MinQuantity || p.Quantity > p.MaxQuantity)) {
                        <li class="list-group-item px-0 text-muted bg-transparent">Todos os produtos estão dentro dos níveis ideais.</li>
                    }
                </ul>
            </div>
        </div>
    </div>
    <div class="col-md-6 mb-4">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-transparent border-0 pt-4 pb-0">
                <h3 class="card-title text-white fs-4 fw-bold">Últimas Movimentações</h3>
            </div>
            <div class="card-body">
                <ul class="list-group list-group-flush bg-transparent">
                    @foreach(var move in ViewBag.RecentMovements)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center px-0 bg-transparent">
                            <div>
                                <strong class="d-block text-white">@move.Product.Name</strong>
                                <small class="text-secondary" style="font-size: 0.8rem;">@move.MovementDate.ToString("dd/MM/yyyy HH:mm")</small>
                            </div>
                            <span>
                                @if(move.Type == MeuErp.Models.MovementType.Entry) {
                                    <span class="text-success fw-bold fs-5" style="text-shadow: 0 0 8px rgba(74, 222, 128, 0.2);">+@move.Quantity</span>
                                } else {
                                    <span class="text-danger fw-bold fs-5" style="text-shadow: 0 0 8px rgba(248, 113, 113, 0.2);">-@move.Quantity</span>
                                }
                            </span>
                        </li>
                    }
                    @if(ViewBag.RecentMovements.Count == 0) {
                        <li class="list-group-item px-0 text-muted bg-transparent">Nenhuma movimentação registrada.</li>
                    }
                </ul>
            </div>
        </div>
    </div>
</div>
