@model MeuErp.Models.Product
@{
    ViewData["Title"] = "Editar Produto";
}

<div class="mb-4">
    <h1 class="page-title text-center">Editar Produto</h1>
</div>

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card p-4">
            <h2 class="fs-4 text-white mb-4 fw-bold text-center">Editar Detalhes</h2>
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 mb-3 fs-6" style="display:none;"></div>
                <input type="hidden" asp-for="Id" />
                
                <div class="mb-3">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger fs-6 mt-1 d-block"></span>
                </div>
                
                <div class="mb-3">
                    <label asp-for="Description" class="form-label"></label>
                    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Description" class="text-danger fs-6 mt-1 d-block"></span>
                </div>
                
                <div class="mb-3">
                    <label asp-for="Price" class="form-label"></label>
                    <div class="input-group">
                        <span class="input-group-text bg-transparent border-secondary text-secondary" style="border-radius: 10px 0 0 10px; border-right: none !important;">R$</span>
                        <input asp-for="Price" type="number" step="0.01" class="form-control" style="border-radius: 0 10px 10px 0;" />
                    </div>
                    <span asp-validation-for="Price" class="text-danger fs-6 mt-1 d-block"></span>
                </div>
                
                <div class="mb-3">
                    <label asp-for="Quantity" class="form-label"></label>
                    <input asp-for="Quantity" type="number" class="form-control" readonly style="background-color: rgba(255, 255, 255, 0.01) !important; border-color: rgba(255, 255, 255, 0.04) !important; color: var(--text-muted) !important;" />
                    <div class="form-text text-secondary" style="font-size: 0.8rem; margin-top: 5px;">A quantidade só pode ser alterada via lançamentos de estoque.</div>
                </div>
                
                <div class="row mb-4">
                    <div class="col">
                        <label asp-for="MinQuantity" class="form-label"></label>
                        <input asp-for="MinQuantity" type="number" class="form-control" />
                        <span asp-validation-for="MinQuantity" class="text-danger fs-6 mt-1 d-block"></span>
                    </div>
                    <div class="col">
                        <label asp-for="MaxQuantity" class="form-label"></label>
                        <input asp-for="MaxQuantity" type="number" class="form-control" />
                        <span asp-validation-for="MaxQuantity" class="text-danger fs-6 mt-1 d-block"></span>
                    </div>
                </div>
                
                <div class="d-flex gap-3 justify-content-end mt-4">
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">Cancelar</a>
                    <button type="submit" class="btn btn-primary px-4">Salvar</button>
                </div>
            </form>
        </div>
    </div>
</div>
