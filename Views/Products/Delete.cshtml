@model MeuErp.Models.Product
@{
    ViewData["Title"] = "Excluir Produto";
}

<div class="mb-4">
    <h1 class="page-title text-center">Excluir Produto</h1>
</div>

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card p-4" style="border-color: rgba(239, 68, 68, 0.4) !important;">
            <h2 class="fs-4 text-danger mb-3 fw-bold text-center">Atenção!</h2>
            <p class="text-secondary text-center mb-4">Tem certeza de que deseja excluir permanentemente este produto?</p>
            
            <div class="p-3 rounded mb-4" style="background: rgba(255, 255, 255, 0.02); border: 1px solid rgba(255, 255, 255, 0.04);">
                <dl class="row mb-0" style="row-gap: 10px;">
                    <dt class="col-sm-4 text-muted mb-0">Nome:</dt>
                    <dd class="col-sm-8 text-white fw-bold mb-0">@Html.DisplayFor(model => model.Name)</dd>

                    <dt class="col-sm-4 text-muted mb-0">Preço:</dt>
                    <dd class="col-sm-8 text-white mb-0">@Model.Price.ToString("C")</dd>

                    <dt class="col-sm-4 text-muted mb-0">Estoque:</dt>
                    <dd class="col-sm-8 text-white mb-0">@Html.DisplayFor(model => model.Quantity)</dd>
                </dl>
            </div>
            
            <form asp-action="Delete" class="d-flex gap-3 justify-content-end">
                <input type="hidden" asp-for="Id" />
                <a asp-action="Index" class="btn btn-outline-secondary px-4">Cancelar</a>
                <button type="submit" class="btn btn-outline-danger px-4">Excluir Produto</button>
            </form>
        </div>
    </div>
</div>
