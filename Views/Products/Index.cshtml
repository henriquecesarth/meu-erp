@model IEnumerable<MeuErp.Models.Product>
@{
    ViewData["Title"] = "Produtos";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="page-title mb-0">Produtos</h1>
    <a asp-action="Create" class="btn btn-primary shadow-sm">Novo Produto</a>
</div>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger mb-4 shadow-sm">@TempData["ErrorMessage"]</div>
}

<div class="card p-4">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>@Html.DisplayNameFor(model => model.Name)</th>
                    <th class="text-end">@Html.DisplayNameFor(model => model.Price)</th>
                    <th class="text-center">@Html.DisplayNameFor(model => model.Quantity)</th>
                    <th class="text-center">Mín / Máx</th>
                    <th class="text-center">Status</th>
                    <th class="text-center" style="width: 180px;">Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model) {
                    var statusBadgeClass = "badge bg-success";
                    var statusText = "Normal";
                    if (item.Quantity < item.MinQuantity) {
                        statusBadgeClass = "badge bg-danger";
                        statusText = "Abaixo do Mín.";
                    } else if (item.Quantity > item.MaxQuantity) {
                        statusBadgeClass = "badge bg-warning text-dark";
                        statusText = "Acima do Máx.";
                    }

                    <tr>
                        <td class="fw-medium text-white">@Html.DisplayFor(modelItem => item.Name)</td>
                        <td class="text-end">@item.Price.ToString("C")</td>
                        <td class="text-center">@Html.DisplayFor(modelItem => item.Quantity)</td>
                        <td class="text-center text-muted">@item.MinQuantity / @item.MaxQuantity</td>
                        <td class="text-center"><span class="@statusBadgeClass">@statusText</span></td>
                        <td class="text-center">
                            <div class="d-flex gap-2 justify-content-center">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary py-1 px-3">Editar</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger py-1 px-3">Excluir</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
